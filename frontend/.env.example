# ───────────────────────────────────────────────────────────────────────
# Frontend env. Copy to frontend/.env for local dev. Variables prefixed
# with VITE_ are inlined at build time — set them BEFORE `npm run build`.
# In Railway, set in the service dashboard.
# ───────────────────────────────────────────────────────────────────────

# Where the API lives. Used for both REST calls (/api/...) and static
# uploaded assets (/uploads/...). NO trailing slash.
# Local dev default: http://localhost:4000
# Railway prod: https://faro-backend.up.railway.app
VITE_API_ORIGIN="http://localhost:4000"
