    "@sasha-licenta/shared": "file:../shared"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/cookie-parser": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/pdfkit": "latest",
    "eslint": "latest",
