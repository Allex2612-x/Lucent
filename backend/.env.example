NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sasha_licenta?schema=public"

# Auth
JWT_ACCESS_SECRET="change_me_access"
JWT_REFRESH_SECRET="change_me_refresh"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# CORS
CORS_ORIGINS="http://localhost:5173"

# Cookies
REFRESH_COOKIE_NAME="refresh_token"
COOKIE_SECURE=false

# --- AI Insights (#8) ---
# Used by /api/insights/weekly. Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# --- OAuth (#12) ---
# Public URL where the backend is reachable (used as redirect base by Google/Facebook)
BACKEND_PUBLIC_URL="http://localhost:5000"
# Where the OAuth flow lands the user after callback
FRONTEND_ORIGIN="http://localhost:5173"

# Google OAuth — leave empty to disable; register an app at https://console.cloud.google.com/
# Authorized redirect URI: ${BACKEND_PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth — leave empty to disable; register an app at https://developers.facebook.com/
# Valid OAuth Redirect URI: ${BACKEND_PUBLIC_URL}/api/auth/facebook/callback
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
