# ───────────────────────────────────────────────────────────────────────
# Backend env. Copy to backend/.env for local dev. In Railway, set
# everything in the service dashboard — do NOT commit real secrets.
# ───────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Postgres — locally point at your own instance. On Railway,
# DATABASE_URL is auto-injected when you attach the Postgres plugin.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sasha_licenta_dev?schema=public"

# JWT secrets — generate two distinct random strings:
#   openssl rand -hex 32
JWT_SECRET="change_me_access_32bytes"
JWT_REFRESH_SECRET="change_me_refresh_32bytes"

# CORS — comma-separated list of allowed frontend origins. In Railway
# set this to your frontend service public URL, e.g.
#   FRONTEND_URL="https://faro-frontend.up.railway.app"
# You can list multiple comma-separated.
FRONTEND_URL=""

# Gemini AI — required for receipt OCR + insights. Get a free key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Resend — required for password-reset emails. Free tier (3000/month).
# Get a key at https://resend.com/api-keys (sign up with GitHub).
RESEND_API_KEY=""
# Sender address. Default `onboarding@resend.dev` works without any DNS
# setup. To send from your own domain, verify it in Resend → Domains.
RESEND_FROM="FARO <onboarding@resend.dev>"

# OAuth — public URL where the backend is reachable. On Railway set
# this to your backend service public URL.
BACKEND_PUBLIC_URL="http://localhost:4000"
# Where the OAuth flow redirects the user after successful login.
FRONTEND_ORIGIN="http://localhost:5173"

# Google OAuth (optional) — leave empty to disable. Register at
# https://console.cloud.google.com/. Authorized redirect URI:
#   ${BACKEND_PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (optional) — register at https://developers.facebook.com/.
# Valid OAuth Redirect URI:
#   ${BACKEND_PUBLIC_URL}/api/auth/facebook/callback
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
