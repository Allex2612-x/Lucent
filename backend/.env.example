NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sasha_licenta?schema=public"

# Auth
JWT_ACCESS_SECRET="change_me_access"
JWT_REFRESH_SECRET="change_me_refresh"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# CORS
CORS_ORIGINS="http://localhost:5173"

# Cookies
REFRESH_COOKIE_NAME="refresh_token"
COOKIE_SECURE=false

# --- AI Insights (#8) ---
# Used by /api/insights/weekly. Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=""
